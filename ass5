#include <iostream>
#include <queue>
using namespace std;

#define MAX 20

// ---------- DFS USING ADJACENCY MATRIX ----------
void DFS(int v, int n, int matrix[MAX][MAX],
         string loc[], bool visited[])
{
    visited[v] = true;
    cout << loc[v] << " ";

    for (int i = 0; i < n; i++)
    {
        if (matrix[v][i] == 1 && !visited[i])
        {
            DFS(i, n, matrix, loc, visited);
        }
    }
}


// ---------- BFS USING ADJACENCY LIST ----------
void BFS(int start, int n, int adjList[MAX][MAX],
         int count[], string loc[])
{
    bool visited[MAX] = {false};
    queue<int> q;

    visited[start] = true;
    q.push(start);

    while (!q.empty())
    {
        int node = q.front();
        q.pop();

        cout << loc[node] << " ";

        for (int i = 0; i < count[node]; i++)
        {
            int neighbor = adjList[node][i];

            if (!visited[neighbor])
            {
                visited[neighbor] = true;
                q.push(neighbor);
            }
        }
    }
}


// ---------- MAIN ----------
int main()
{
    int n;
    string loc[MAX];
    int matrix[MAX][MAX];
    int adjList[MAX][MAX];
    int count[MAX] = {0};

    cout << "Enter number of locations: ";
    cin >> n;

    // Input locations
    for (int i = 0; i < n; i++)
    {
        cout << "Enter name of location #" << i << ": ";
        cin >> loc[i];
    }

    // Input adjacency matrix
    cout << "\nEnter connection (1 if connected, 0 if not):\n";

    for (int i = 0; i < n; i++)
    {
        for (int j = i + 1; j < n; j++)
        {
            cout << "Connection between "
                 << loc[i] << " and " << loc[j] << ": ";

            cin >> matrix[i][j];
            matrix[j][i] = matrix[i][j];
        }
        matrix[i][i] = 0;
    }

    // Display matrix
    cout << "\nAdjacency Matrix:\n";
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
            cout << matrix[i][j] << " ";
        cout << endl;
    }

    // ---------- CREATE ADJACENCY LIST ----------
    for (int i = 0; i < n; i++)
    {
        for (int j = 0; j < n; j++)
        {
            if (matrix[i][j] == 1)
            {
                adjList[i][count[i]] = j;
                count[i]++;
            }
        }
    }

    int start;
    cout << "\nEnter starting vertex index: ";
    cin >> start;

    // ---------- DFS ----------
    bool visited[MAX] = {false};

    cout << "\nDepth First Search (DFS) Traversal:\n";
    DFS(start, n, matrix, loc, visited);

    // ---------- BFS ----------
    cout << "\n\nBreadth First Search (BFS) Traversal:\n";
    BFS(start, n, adjList, count, loc);

    return 0;
}