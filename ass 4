#include <iostream>
#include <string.h>
#include <ctype.h>
using namespace std;

struct node
{
    char data;
    node *left;
    node *right;
};

class stack1
{
    node *data[100];   // Increased stack size
    int top;

public:
    stack1()
    {
        top = -1;
    }

    int empty()
    {
        return (top == -1);
    }

    void push(node *p)
    {
        if (top < 99)
            data[++top] = p;
    }

    node *pop()
    {
        if (top >= 0)
            return data[top--];
        return NULL;
    }
};

class tree
{
public:
    node *top;

    void expression(char[]);
    void display(node *);
    void non_rec_postorder(node *);
    void del(node *);
};

void tree::expression(char prefix[])
{
    stack1 s;
    node *t1, *t2;

    int len = strlen(prefix);

    for (int i = len - 1; i >= 0; i--)
    {
        node *newnode = new node;
        newnode->left = NULL;
        newnode->right = NULL;

        if (isalpha(prefix[i]))   // operand
        {
            newnode->data = prefix[i];
            s.push(newnode);
        }
        else if (prefix[i] == '+' || prefix[i] == '-' ||
                 prefix[i] == '*' || prefix[i] == '/')
        {
            t1 = s.pop();
            t2 = s.pop();

            newnode->data = prefix[i];
            newnode->left = t1;
            newnode->right = t2;

            s.push(newnode);
        }
    }

    top = s.pop();
}

void tree::display(node *root)   // Preorder
{
    if (root != NULL)
    {
        cout << root->data;
        display(root->left);
        display(root->right);
    }
}

void tree::non_rec_postorder(node *root)
{
    if (root == NULL)
        return;

    stack1 s1, s2;
    node *temp;

    s1.push(root);

    while (!s1.empty())
    {
        temp = s1.pop();
        s2.push(temp);

        if (temp->left)
            s1.push(temp->left);

        if (temp->right)
            s1.push(temp->right);
    }

    while (!s2.empty())
    {
        temp = s2.pop();
        cout << temp->data;
    }
}

void tree::del(node *root)
{
    if (root == NULL)
        return;

    del(root->left);
    del(root->right);

    delete root;   // Correct deletion
}

int main()
{
    char expr[100];   // Increased input size
    tree t;

    cout << "Enter Prefix Expression : ";
    cin >> expr;

    t.expression(expr);

    cout << "\nPreorder Expression : ";
    t.display(t.top);

    cout << "\nPostorder Expression : ";
    t.non_rec_postorder(t.top);

    t.del(t.top);

    cout << "\nTree deleted successfully.";

    return 0;
}