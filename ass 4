#include <iostream>
#include <cstring>
using namespace std;

struct node
{
    char data;
    node *left;
    node *right;
};

class stack1
{
    node *data[30];
    int top;

public:
    stack1()
    {
        top = -1;
    }

    int empty()
    {
        if (top == -1)
            return 1;
        return 0;
    }

    void push(node *p)
    {
        data[++top] = p;
    }

    node *pop()
    {
        return data[top--];
    }
};

class tree
{
public:
    node *top;

    void expression(char prefix[]);
    void display(node *);
    void non_rec_postorder(node *);
    void del(node *);
};

int isOperator(char c)
{
    if (c == '+' || c == '-' || c == '*' || c == '/' || c == '^')
        return 1;
    return 0;
}

void tree::expression(char prefix[])
{
    stack1 s;
    int len = strlen(prefix);

    for (int i = len - 1; i >= 0; i--)
    {
        node *temp = new node;
        temp->left = NULL;
        temp->right = NULL;

        if (!isOperator(prefix[i]))  // operand
        {
            temp->data = prefix[i];
            s.push(temp);
        }
        else
        {
            temp->data = prefix[i];
            temp->left = s.pop();
            temp->right = s.pop();
            s.push(temp);
        }
    }

    top = s.pop();
}

void tree::display(node *root)  // preorder
{
    if (root != NULL)
    {
        cout << root->data;
        display(root->left);
        display(root->right);
    }
}

void tree::non_rec_postorder(node *root)
{
    stack1 s1, s2;
    node *temp;

    s1.push(root);

    while (!s1.empty())
    {
        temp = s1.pop();
        s2.push(temp);

        if (temp->left != NULL)
            s1.push(temp->left);

        if (temp->right != NULL)
            s1.push(temp->right);
    }

    while (!s2.empty())
    {
        temp = s2.pop();
        cout << temp->data;
    }
}

void tree::del(node *root)
{
    if (root == NULL)
        return;

    del(root->left);
    del(root->right);

    cout << "\nDeleting node: " << root->data;
    delete root;
}

int main()
{
    tree t;
    char expr[20];

    cout << "Enter Prefix Expression: ";
    cin >> expr;

    t.expression(expr);

    cout << "\nPreorder Expression: ";
    t.display(t.top);

    cout << "\nPostorder (Non-Recursive): ";
    t.non_rec_postorder(t.top);

    t.del(t.top);

    return 0;
}