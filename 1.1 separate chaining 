#include <iostream>
using namespace std;

struct Node {
    int id;
    int qty;
    Node* next;
};

class HashChain {
    int size;
    Node* table[10];

public:
    HashChain(int s) {
        size = s;
        for(int i = 0; i < size; i++) {
            table[i] = NULL;
        }
    }

    int hash(int key) {
        return key % size;
    }

    void insert(int key, int q) {
        int index = hash(key);

        Node* newNode = new Node();
        newNode->id = key;
        newNode->qty = q;
        newNode->next = table[index]; // insert at beginning

        table[index] = newNode;
    }

    void search(int key) {
        int index = hash(key);
        Node* temp = table[index];

        while(temp != NULL) {
            if(temp->id == key) {
                cout << "Found ID " << key << " with Qty " << temp->qty << endl;
                return;
            }
            temp = temp->next;
        }

        cout << "ID not found\n";
    }

    void display() {
        for(int i = 0; i < size; i++) {
            cout << i << " -> ";
            Node* temp = table[i];

            while(temp != NULL) {
                cout << "[" << temp->id << "," << temp->qty << "] -> ";
                temp = temp->next;
            }
            cout << "NULL\n";
        }
    }
};

int main() {
    HashChain h(5);
    int choice, id, qty;

    do {
        cout << "\n1.Insert\n2.Search\n3.Display\n4.Exit\n";
        cin >> choice;

        switch(choice) {
            case 1:
                cout << "Enter ID: ";
                cin >> id;
                cout << "Enter Qty: ";
                cin >> qty;
                h.insert(id, qty);
                break;

            case 2:
                cout << "Enter ID to search: ";
                cin >> id;
                h.search(id);
                break;

            case 3:
                h.display();
                break;
        }
    } while(choice != 4);

    return 0;
}